# walk4change backend — environment variables.
# For LOCAL dev these defaults match docker-compose / scripts/dev-up.sh.
# For PROD, point DATABASE_URL at Supabase and set a real JWT_SECRET + exact CORS.

# Local Postgres (host access). Inside Docker the API uses db:5432 instead.
DATABASE_URL=postgres://walk:walk@localhost:5433/walk4change
TEST_DATABASE_URL=postgres://walk:walk@localhost:5433/walk4change

# Must be >= 32 characters.
JWT_SECRET=change-me-to-a-32-byte-min-random-secret-string

BIND_ADDR=0.0.0.0:8080

# Comma-separated exact origins. 5173 = Vite dev server (frontend web/).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Stable password for the demo users created by the seeder (Ana & Bek).
SEED_PASSWORD=demodemo
