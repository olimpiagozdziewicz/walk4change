# Copy to deploy/.env.deploy and fill in. NEVER commit the real file.
GCP_PROJECT=your-gcp-project-id
GCP_REGION=europe-central2
GOOGLE_KEY_FILE=/absolute/path/to/service-account-key.json
# Supabase SESSION-mode connection string (NOT transaction pooler — migrations
# need session-level advisory locks). From Supabase: Project → Connect → Session pooler.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Leave blank to auto-generate. Must be >=32 chars.
JWT_SECRET=
# Set after the Vercel URL is known.
CORS_ALLOWED_ORIGINS=https://walk4change.vercel.app
