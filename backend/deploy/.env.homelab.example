# Copy to deploy/.env.homelab and fill in. NEVER commit the real file.
# Supabase SESSION pooler (IPv4, supports migration advisory locks):
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
JWT_SECRET=replace-with-a-32-plus-char-random-secret
CORS_ALLOWED_ORIGINS=https://<your-app>.vercel.app
# Optional: stable named tunnel (recommended). Get from Cloudflare Zero Trust >
# Networks > Tunnels > create tunnel > copy token; map a hostname to localhost:8080.
# CLOUDFLARED_TUNNEL_TOKEN=
